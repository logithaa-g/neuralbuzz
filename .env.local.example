# Pusher (https://pusher.com - free tier: 100 connections, 200k messages/day)
PUSHER_APP_ID=your_pusher_app_id
PUSHER_APP_KEY=your_pusher_key
PUSHER_APP_SECRET=your_pusher_secret
PUSHER_APP_CLUSTER=ap2

NEXT_PUBLIC_PUSHER_APP_KEY=your_pusher_key
NEXT_PUBLIC_PUSHER_APP_CLUSTER=ap2

# Vercel KV (Redis) - add via Vercel dashboard > Storage > KV
KV_URL=your_kv_url
KV_REST_API_URL=your_kv_rest_api_url
KV_REST_API_TOKEN=your_kv_rest_api_token
KV_REST_API_READ_ONLY_TOKEN=your_kv_rest_api_read_only_token

# App URL (set to your vercel deployment URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
